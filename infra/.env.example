# Base de datos
DATABASE_URL=postgresql://tfg:tfg@db:5432/tfg
POSTGRES_USER=tfg
POSTGRES_PASSWORD=tfg
POSTGRES_DB=tfg

# API / Web
VITE_API_BASE_URL=http://localhost:8000
API_BASE_URL=http://api:8000
API_JWT_SECRET=cambiame-api-jwt
JWT_EXPIRATION_MINUTES=30

# Servicios geográficos (OSRM para ruteo por calle)
OSRM_URL=http://osrm:5000

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tfg.local
RESET_TOKEN_TTL_SECONDS=3600

# Ingesta SEPA
SEPA_PORTAL_URL=https://datos.produccion.gob.ar
CKAN_DATASET_ID=sepa-precios
SEPA_DOWNLOAD_DIR=/data/sepa
SEPA_FECHA_LOTE=
PRODUCTOS_CHUNK_SIZE=150000

# Defaults de optimización
DEFAULT_MAX_PARADAS=3
DEFAULT_PREFERENCIA=MENOR_PRECIO
